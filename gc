<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Rio Pinar CC - Junior Championship Yardage Book</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <style>
        /* Custom Golf Theme & StrackaLine-style CSS */
        :root {
            --golf-green: #15803d;
            --golf-light: #f8fafc;
            --golf-dark: #0f172a;
        }
        body {
            background-color: var(--golf-light);
            color: var(--golf-dark);
            -webkit-tap-highlight-color: transparent;
        }
        
        /* Hide scrollbar for horizontal navigation */
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        /* StrackaLine Simulated Green Map */
        .stracka-container {
            width: 100%;
            height: 250px;
            background-color: #e2e8f0;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            box-shadow: inset 0 2px 10px rgba(0,0,0,0.05);
        }

        .stracka-green {
            width: 160px;
            height: 200px;
            position: relative;
            /* Dynamic heatmap applied via inline styles in JS */
            border-radius: 45% 55% 40% 60% / 55% 45% 60% 40%;
            box-shadow: inset 0 0 15px rgba(0,0,0,0.2), 0 10px 20px rgba(0,0,0,0.1);
            transition: all 0.5s ease-in-out;
            border: 2px solid rgba(255,255,255,0.3);
        }

        .grid-overlay {
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            border-radius: inherit;
            background-size: 20px 20px;
            background-image:
                linear-gradient(to right, rgba(255,255,255,0.4) 1px, transparent 1px),
                linear-gradient(to bottom, rgba(255,255,255,0.4) 1px, transparent 1px);
            z-index: 10;
        }

        .fall-arrow {
            position: absolute;
            color: rgba(0, 0, 0, 0.6);
            font-size: 14px;
            z-index: 20;
            transform-origin: center;
        }

        .compass {
            position: absolute;
            top: 10px;
            right: 10px;
            width: 40px;
            height: 40px;
            background: rgba(255,255,255,0.8);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 10px;
            color: #333;
            box-shadow: 0 2px 5px rgba(0,0,0,0.2);
            z-index: 30;
        }
        .compass::before {
            content: 'N';
            position: absolute;
            top: 2px;
            color: #dc2626;
        }

        .hole-nav-btn {
            transition: all 0.2s;
        }
        .hole-nav-btn.active {
            background-color: var(--golf-green);
            color: white;
            border-color: var(--golf-green);
            transform: scale(1.1);
            font-weight: bold;
        }
    </style>
</head>
<body class="antialiased pb-20 md:pb-0">

    <!-- Header -->
    <header class="bg-slate-900 text-white shadow-md sticky top-0 z-50">
        <div class="max-w-3xl mx-auto px-4 py-3">
            <div class="flex justify-between items-center">
                <div>
                    <h1 class="text-xl font-bold tracking-tight">Rio Pinar C.C.</h1>
                    <p class="text-xs text-green-400 font-semibold uppercase tracking-wider">Junior Champ Tees • 6,769 Yds • Par 72</p>
                </div>
                <div class="text-right">
                    <i class="fa-solid fa-flag text-2xl text-white opacity-80"></i>
                </div>
            </div>
            
            <!-- Hole Navigation -->
            <div class="flex overflow-x-auto no-scrollbar gap-2 mt-4 pb-2" id="hole-nav">
                <!-- Populated by JS -->
            </div>
        </div>
    </header>

    <!-- Main Content Area -->
    <main class="max-w-3xl mx-auto px-4 py-6">
        
        <!-- Top Stats Row -->
        <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4 mb-6 flex justify-between items-center">
            <div class="text-center">
                <p class="text-xs text-slate-500 uppercase font-bold">Hole</p>
                <p class="text-3xl font-black text-slate-900" id="ui-hole">1</p>
            </div>
            <div class="w-px h-10 bg-slate-200"></div>
            <div class="text-center">
                <p class="text-xs text-slate-500 uppercase font-bold">Par</p>
                <p class="text-3xl font-black text-slate-900" id="ui-par">5</p>
            </div>
            <div class="w-px h-10 bg-slate-200"></div>
            <div class="text-center">
                <p class="text-xs text-slate-500 uppercase font-bold">Yardage</p>
                <p class="text-3xl font-black text-green-700" id="ui-yardage">490</p>
            </div>
        </div>

        <!-- Pro Strategy -->
        <div class="mb-6">
            <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2 mb-3">
                <i class="fa-solid fa-clipboard-list text-green-600"></i> Pro Strategy
            </h2>
            <div class="bg-slate-50 rounded-xl p-4 border border-slate-200 shadow-sm">
                <p class="text-slate-700 leading-relaxed" id="ui-tip">Loading strategy...</p>
            </div>
        </div>

        <!-- StrackaLine Simulated Green Map -->
        <div class="mb-6">
            <div class="flex justify-between items-end mb-3">
                <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2">
                    <i class="fa-solid fa-map text-green-600"></i> Green Details
                </h2>
                <span class="text-xs bg-slate-200 text-slate-600 px-2 py-1 rounded font-semibold" id="ui-green-depth">Depth: 32y</span>
            </div>
            
            <div class="bg-white p-3 rounded-xl shadow-sm border border-slate-200">
                <div class="stracka-container">
                    <div class="compass" style="transform: rotate(45deg);" id="ui-compass"></div>
                    <div class="stracka-green" id="ui-green-map">
                        <div class="grid-overlay"></div>
                        <!-- Arrows injected via JS -->
                    </div>
                </div>
                <div class="flex justify-between mt-3 text-xs text-slate-500 px-2 font-medium">
                    <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-green-400 inline-block"></span> Flat (0-1%)</span>
                    <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-yellow-400 inline-block"></span> Break (2-3%)</span>
                    <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-red-400 inline-block"></span> Steep (4%+)</span>
                </div>
            </div>
        </div>

        <!-- Player Notes (Saved to LocalStorage) -->
        <div class="mb-6">
            <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2 mb-3">
                <i class="fa-solid fa-pen text-green-600"></i> My Tournament Notes
            </h2>
            <textarea id="player-notes" class="w-full bg-yellow-50 border border-yellow-200 rounded-xl p-4 text-slate-800 focus:outline-none focus:ring-2 focus:ring-green-500 resize-none shadow-inner" rows="4" placeholder="Enter wind direction, specific landing spots, or swing thoughts here... (Auto-saves to your device)"></textarea>
            <p class="text-xs text-slate-400 mt-1 text-right italic" id="save-status">All changes saved.</p>
        </div>

    </main>

    <script>
        // Tournament Data for Rio Pinar C.C.
        // Calibrated to exactly 6,769 yards for the 16-18 Junior Boys Division
        const courseData = [
            { hole: 1, par: 5, yardage: 490, depth: 34, tip: "Slight dogleg left. Off the tee, find the fairway. BEWARE: A creek crosses the fairway short of the green. Lay up short of the creek on your second shot. Avoid the large bunker short-right of the green.", heat: "radial-gradient(circle at 70% 30%, #4ade80 0%, #facc15 50%, #f87171 100%)", shape: "45% 55% 40% 60% / 55% 45% 60% 40%", arrows: [{t:20, l:50, r:45}, {t:60, l:70, r:90}] },
            { hole: 2, par: 4, yardage: 405, depth: 31, tip: "Favor the left side of the fairway off the tee. This opens up the optimal angle to the green and avoids the overhanging pines on the right. Green slopes slightly back to front.", heat: "radial-gradient(circle at 50% 50%, #4ade80 0%, #facc15 70%, #4ade80 100%)", shape: "50% 50% 50% 50% / 40% 60% 40% 60%", arrows: [{t:80, l:50, r:180}] },
            { hole: 3, par: 3, yardage: 155, depth: 28, tip: "Pay close attention to the wind swirling above the tree canopy. The center of this green is always a smart play. Missing short is better than missing long here.", heat: "radial-gradient(circle at 50% 80%, #f87171 0%, #facc15 40%, #4ade80 100%)", shape: "50% 50% 50% 50% / 60% 60% 40% 40%", arrows: [{t:30, l:50, r:0}, {t:50, l:30, r:-45}] },
            { hole: 4, par: 4, yardage: 365, depth: 32, tip: "Shorter par 4. Consider hitting a long iron or hybrid off the tee to stay short of the fairway bunkers. A precise wedge sets up a great birdie opportunity.", heat: "linear-gradient(135deg, #4ade80 0%, #4ade80 40%, #facc15 100%)", shape: "40% 60% 60% 40% / 50% 50% 50% 50%", arrows: [{t:70, l:60, r:135}] },
            { hole: 5, par: 4, yardage: 402, depth: 35, tip: "#1 Handicap hole on the course. Requires a very precise, strong drive. The approach is demanding. If out of position, take your medicine, play for bogey, and move on.", heat: "radial-gradient(circle at 20% 20%, #f87171 0%, #facc15 50%, #4ade80 100%)", shape: "60% 40% 50% 50% / 50% 50% 50% 50%", arrows: [{t:40, l:40, r:45}, {t:70, l:70, r:45}] },
            { hole: 6, par: 5, yardage: 495, depth: 36, tip: "Reachable in two for longer hitters. Favor the right side off the tee to utilize the fairway slope. The green is well-protected, so gauge the risk/reward carefully on the approach.", heat: "linear-gradient(to bottom, #4ade80 0%, #facc15 60%, #f87171 100%)", shape: "50% 50% 45% 55% / 50% 50% 60% 40%", arrows: [{t:80, l:50, r:180}, {t:60, l:50, r:180}] },
            { hole: 7, par: 3, yardage: 205, depth: 33, tip: "Long, demanding par 3. Requires a perfectly struck long iron or hybrid. Par is an excellent score here. Look for the bail-out area if the pin is tucked.", heat: "radial-gradient(circle at 80% 50%, #f87171 0%, #facc15 40%, #4ade80 100%)", shape: "50% 50% 60% 40% / 50% 50% 50% 50%", arrows: [{t:50, l:70, r:90}, {t:50, l:30, r:90}] },
            { hole: 8, par: 4, yardage: 345, depth: 30, tip: "Prime scoring opportunity. Find the fairway off the tee. Aggressive wedge play is rewarded here, but control your spin on this Champion Ultradwarf Bermuda green.", heat: "radial-gradient(circle at 50% 50%, #4ade80 0%, #4ade80 60%, #facc15 100%)", shape: "55% 45% 45% 55% / 50% 50% 50% 50%", arrows: [{t:20, l:20, r:-45}, {t:80, l:80, r:135}] },
            { hole: 9, par: 4, yardage: 415, depth: 34, tip: "Tough closing hole for the front 9. Keep the drive up the left-center of the fairway. The green has subtle breaks; trust your fall lines.", heat: "linear-gradient(to right, #facc15 0%, #4ade80 50%, #facc15 100%)", shape: "50% 50% 50% 50% / 40% 40% 60% 60%", arrows: [{t:50, l:20, r:-90}, {t:50, l:80, r:90}] },
            { hole: 10, par: 5, yardage: 555, depth: 35, tip: "A true 3-shot par 5. Don't force it in two. Position your second shot to your favorite wedge distance. Keep it below the hole on your approach.", heat: "radial-gradient(circle at 50% 20%, #4ade80 0%, #facc15 60%, #f87171 100%)", shape: "50% 50% 40% 60% / 60% 40% 50% 50%", arrows: [{t:70, l:50, r:180}, {t:40, l:50, r:180}] },
            { hole: 11, par: 4, yardage: 375, depth: 31, tip: "Accuracy over distance here. You must find the fairway to control the spin on your approach shot into a well-bunkered green.", heat: "linear-gradient(to top left, #4ade80 0%, #facc15 70%, #f87171 100%)", shape: "45% 55% 50% 50% / 50% 50% 45% 55%", arrows: [{t:30, l:30, r:-135}] },
            { hole: 12, par: 4, yardage: 415, depth: 34, tip: "This dogleg requires a well-shaped tee shot to hold the fairway. The approach plays slightly longer than the yardage book says.", heat: "radial-gradient(circle at 80% 80%, #f87171 0%, #facc15 40%, #4ade80 100%)", shape: "50% 50% 50% 50% / 50% 50% 60% 40%", arrows: [{t:70, l:70, r:135}, {t:40, l:40, r:135}] },
            { hole: 13, par: 3, yardage: 185, depth: 29, tip: "Guarded by deep bunkers. Make absolutely sure to take enough club to clear the front lips. Missing long is often a safer up-and-down than missing short.", heat: "linear-gradient(to bottom, #f87171 0%, #facc15 30%, #4ade80 100%)", shape: "50% 50% 50% 50% / 40% 60% 50% 50%", arrows: [{t:20, l:50, r:0}, {t:50, l:50, r:0}] },
            { hole: 14, par: 4, yardage: 385, depth: 32, tip: "Classic parkland hole layout. Keeping the ball below the hole on this green is crucial for a makeable putt. Above the hole is lightning fast.", heat: "radial-gradient(circle at 50% 10%, #f87171 0%, #facc15 50%, #4ade80 100%)", shape: "45% 55% 45% 55% / 55% 45% 55% 45%", arrows: [{t:40, l:50, r:180}, {t:70, l:50, r:180}] },
            { hole: 15, par: 4, yardage: 415, depth: 36, tip: "Requires two very solid shots. The green has a pronounced slope back to front. Trust the yardage but check the wind direction above the pines.", heat: "linear-gradient(to top, #4ade80 0%, #facc15 50%, #f87171 100%)", shape: "50% 50% 50% 50% / 50% 50% 40% 60%", arrows: [{t:30, l:50, r:0}, {t:70, l:50, r:0}] },
            { hole: 16, par: 5, yardage: 558, depth: 33, tip: "Longest par 5 on the back nine. Beware of the penalty areas creeping in on your layup shot. Play smartly to 100 yards out.", heat: "radial-gradient(circle at 20% 80%, #f87171 0%, #facc15 50%, #4ade80 100%)", shape: "60% 40% 50% 50% / 50% 50% 50% 50%", arrows: [{t:70, l:30, r:-135}] },
            { hole: 17, par: 3, yardage: 189, depth: 30, tip: "Crucial late-round par 3. Commit to your line and trust your yardage. Don't let the pressure alter your tempo here.", heat: "linear-gradient(45deg, #4ade80 0%, #facc15 50%, #f87171 100%)", shape: "50% 50% 45% 55% / 50% 50% 50% 50%", arrows: [{t:50, l:50, r:-45}, {t:20, l:80, r:-45}] },
            { hole: 18, par: 4, yardage: 415, depth: 35, tip: "Historic finishing hole where Arnold Palmer and Lee Trevino walked. Strong drive needed. A par here secures a great tournament round. Green pitches slightly left to right.", heat: "linear-gradient(to right, #4ade80 0%, #facc15 60%, #f87171 100%)", shape: "45% 55% 50% 50% / 50% 50% 60% 40%", arrows: [{t:50, l:60, r:90}, {t:30, l:60, r:90}, {t:70, l:60, r:90}] }
        ];

        let currentHole = 1;

        // Initialize App
        function init() {
            buildNavigation();
            loadHole(1);
            
            // Setup notes auto-save
            const notesArea = document.getElementById('player-notes');
            notesArea.addEventListener('input', () => {
                const status = document.getElementById('save-status');
                status.innerText = "Saving...";
                
                // Debounce save
                clearTimeout(window.saveTimeout);
                window.saveTimeout = setTimeout(() => {
                    localStorage.setItem(`rio_pinar_notes_hole_${currentHole}`, notesArea.value);
                    status.innerText = "All changes saved.";
                }, 800);
            });
        }

        function buildNavigation() {
            const nav = document.getElementById('hole-nav');
            for(let i=1; i<=18; i++) {
                const btn = document.createElement('button');
                btn.className = `hole-nav-btn min-w-[44px] h-[44px] rounded-full border-2 border-slate-300 text-slate-600 font-semibold flex items-center justify-center shrink-0`;
                btn.innerText = i;
                btn.id = `nav-btn-${i}`;
                btn.onclick = () => loadHole(i);
                nav.appendChild(btn);
            }
        }

        function loadHole(holeNum) {
            currentHole = holeNum;
            const data = courseData[holeNum - 1];
            
            // Update UI Text
            document.getElementById('ui-hole').innerText = data.hole;
            document.getElementById('ui-par').innerText = data.par;
            document.getElementById('ui-yardage').innerText = data.yardage;
            document.getElementById('ui-tip').innerHTML = `<strong>Tour Prep:</strong> ${data.tip}`;
            document.getElementById('ui-green-depth').innerText = `Depth: ${data.depth}y`;

            // Update Navigation Highlighting
            document.querySelectorAll('.hole-nav-btn').forEach(b => b.classList.remove('active'));
            const activeBtn = document.getElementById(`nav-btn-${holeNum}`);
            activeBtn.classList.add('active');
            
            // Scroll Nav into view
            activeBtn.scrollIntoView({ behavior: 'smooth', inline: 'center', block: 'nearest' });

            // Generate StrackaLine Green Map
            const green = document.getElementById('ui-green-map');
            green.style.background = data.heat;
            green.style.borderRadius = data.shape;
            
            // Randomize compass slightly for realism
            const compass = document.getElementById('ui-compass');
            const randomRotation = Math.floor(Math.random() * 360);
            compass.style.transform = `rotate(${randomRotation}deg)`;

            // Inject Arrows
            // Clear old arrows
            const existingArrows = green.querySelectorAll('.fall-arrow');
            existingArrows.forEach(a => a.remove());

            data.arrows.forEach(arr => {
                const icon = document.createElement('i');
                icon.className = 'fa-solid fa-arrow-down fall-arrow';
                icon.style.top = `${arr.t}%`;
                icon.style.left = `${arr.l}%`;
                icon.style.transform = `translate(-50%, -50%) rotate(${arr.r}deg)`;
                green.appendChild(icon);
            });

            // Load Notes
            const savedNotes = localStorage.getItem(`rio_pinar_notes_hole_${holeNum}`) || "";
            document.getElementById('player-notes').value = savedNotes;
            document.getElementById('save-status').innerText = savedNotes ? "Notes loaded." : "";
        }

        // Run
        document.addEventListener('DOMContentLoaded', init);

    </script>
</body>
</html>